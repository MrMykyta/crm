{
  "templateName": "Korekta - domyslna",
  "documentTypeKey": "korekta",
  "schemaVersion": 1,
  "defaultLocale": "pl",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 20,
      "right": 15,
      "bottom": 20,
      "left": 15
    }
  },
  "sections": [
    {
      "key": "header",
      "type": "header",
      "order": 0,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "document_title_main",
          "type": "document_title",
          "props": {
            "uppercase": true,
            "align": "left",
            "fallbackLabel": "Korekta"
          },
          "bindings": {
            "primary": {
              "path": "document.typeLabel"
            }
          }
        },
        {
          "key": "document_number_main",
          "type": "document_number",
          "props": {
            "label": "Nr",
            "showLabel": true
          },
          "bindings": {
            "number": {
              "path": "document.number"
            }
          }
        }
      ]
    },
    {
      "key": "seller_buyer",
      "type": "seller_buyer",
      "order": 1,
      "enabled": true,
      "locked": false,
      "layoutMode": "grid",
      "blocks": [
        {
          "key": "seller_identity",
          "type": "company_identity",
          "props": {
            "showAddress": true,
            "showNip": true,
            "showRegon": true,
            "showBankAccount": false
          },
          "layout": {
            "widthMode": "fraction",
            "widthValue": 0.5,
            "minWidthPx": 220
          }
        },
        {
          "key": "buyer_identity",
          "type": "counterparty_identity",
          "props": {
            "label": "Odbiorca korekty",
            "showAddress": true,
            "showNip": true,
            "showRegon": false
          },
          "layout": {
            "widthMode": "fraction",
            "widthValue": 0.5,
            "minWidthPx": 220
          }
        }
      ]
    },
    {
      "key": "document_meta",
      "type": "document_meta",
      "order": 2,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "document_dates_main",
          "type": "document_dates",
          "props": {
            "showIssueDate": true,
            "showSaleDate": true,
            "showDueDate": true
          },
          "bindings": {
            "issueDate": {
              "path": "document.issueDate"
            },
            "saleDate": {
              "path": "document.saleDate"
            },
            "dueDate": {
              "path": "payment.dueDate"
            }
          }
        }
      ]
    },
    {
      "key": "items_table",
      "type": "items_table",
      "order": 3,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "items_table_main",
          "type": "items_table",
          "props": {
            "showHeader": true,
            "columns": [
              "lp",
              "name",
              "quantity",
              "unit",
              "unitNetPrice",
              "vatRate",
              "netAmount",
              "vatAmount",
              "grossAmount"
            ]
          },
          "bindings": {
            "items": {
              "path": "items"
            }
          }
        }
      ]
    },
    {
      "key": "totals",
      "type": "totals",
      "order": 4,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "totals_table_main",
          "type": "totals_table",
          "props": {
            "showByVatRate": true,
            "showCurrency": true
          },
          "bindings": {
            "totals": {
              "path": "totals"
            },
            "currency": {
              "path": "document.currency"
            }
          }
        }
      ]
    },
    {
      "key": "notes",
      "type": "notes",
      "order": 5,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "notes_main",
          "type": "notes",
          "props": {
            "label": "Powod korekty / Uwagi"
          },
          "bindings": {
            "primary": {
              "path": "document.notes"
            }
          }
        }
      ]
    },
    {
      "key": "legal_footer",
      "type": "legal_footer",
      "order": 6,
      "enabled": true,
      "locked": true,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "legal_footer_main",
          "type": "legal_footer",
          "props": {
            "allowAppendOnly": true,
            "showKsefReference": true
          }
        }
      ]
    }
  ],
  "styleTokens": {
    "fontSizeBase": 11,
    "colorText": "#111827",
    "colorMuted": "#64748b",
    "colorAccent": "#2563eb",
    "colorBorder": "#e2e8f0"
  },
  "locales": {
    "pl": {}
  },
  "printSettings": {
    "headerRepeat": true,
    "tableHeaderRepeat": true,
    "pageBreakBefore": [],
    "orphanControl": true
  },
  "legalConstraints": {
    "inherited": true,
    "documentTypeKey": "korekta",
    "overrides": []
  },
  "numberingPresetKey": null,
  "layoutPresetKey": null
}
