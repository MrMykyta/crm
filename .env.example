# App
NODE_ENV=production
PORT=3000
APP_PUBLIC_URL=http://146.59.232.254
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80,http://localhost:3000,http://127.0.0.1:3000,http://146.59.232.254,http://146.59.232.254:80

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=app
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_AUTH_SOURCE=admin
# Optional override
# MONGO_URI=mongodb://user:pass@mongo:27017/app?authSource=admin

# Files System
FILES_STORAGE_ROOT=
FILES_MAX_SIZE_MB=20
FILES_PUBLIC_ENABLED=true
FILES_SIGNING_SECRET=dev-files-secret
FILES_SIGNED_URL_TTL_SEC=86400
