# ============================================================
# LOCAL DEV environment — committed, SAFE defaults only.
# Loaded automatically when NODE_ENV !== production (see src/config/loadEnv.js).
# DO NOT put real production secrets here. Production uses .env (gitignored).
#
# Recommended local run (containerized, mirrors prod):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# In that flow the API runs inside the compose network, so DB/Mongo hosts are the
# service names "postgres"/"mongo" below.
#
# Running tooling on the host (npm run dev / smoke / migrate) instead of in a
# container? Then publish the Postgres/Mongo ports and override DB_HOST/MONGO_HOST
# to 127.0.0.1, or just exec into the container:  docker compose exec api npm run <script>
# ============================================================

# App
NODE_ENV=development
PORT=5001
APP_PUBLIC_URL=http://localhost:5001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5001,http://127.0.0.1:5001,http://localhost,http://127.0.0.1

# PostgreSQL (docker-compose service "postgres", defaults app/app/app)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app

# MongoDB (docker-compose service "mongo", defaults root/root)
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=app
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_AUTH_SOURCE=admin
# MONGO_URI=mongodb://root:root@mongo:27017/app?authSource=admin

# Auth / JWT — DEV ONLY secrets (never reuse in production)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=10m
JWT_REFRESH_TTL_HOURS=4

# Files
FILES_STORAGE_ROOT=/app/uploads
FILES_MAX_SIZE_MB=20
FILES_PUBLIC_ENABLED=true
FILES_SIGNING_SECRET=dev-files-secret
FILES_SIGNED_URL_TTL_SEC=86400

# Mail — left blank in dev (outgoing email is a no-op until configured)
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME=CRM Dev
MAIL_FROM_ADDR=dev@example.local

# Company registry lookup — local sandbox QA only.
# Keep keys out of git. Put the official GUS sandbox key in local env/.env override.
# GUS_BIR_ENV=test
# GUS_BIR_API_KEY=<official sandbox key from https://api.stat.gov.pl/Home/RegonApi>
# GUS_BIR_TIMEOUT_MS=5000
# GUS_BIR_LIVE_NIP=<official sandbox NIP, e.g. 5261040828>
