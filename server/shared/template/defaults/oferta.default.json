{
  "templateName": "Oferta - domyslna",
  "documentTypeKey": "oferta",
  "schemaVersion": 1,
  "defaultLocale": "pl",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 20,
      "right": 15,
      "bottom": 20,
      "left": 15
    }
  },
  "sections": [
    {
      "key": "header",
      "type": "header",
      "order": 0,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "document_title_main",
          "type": "document_title",
          "props": {
            "uppercase": true,
            "align": "left",
            "fallbackLabel": "Oferta Handlowa"
          },
          "bindings": {
            "primary": {
              "path": "document.typeLabel"
            }
          }
        },
        {
          "key": "document_number_main",
          "type": "document_number",
          "props": {
            "label": "Nr",
            "showLabel": true
          },
          "bindings": {
            "number": {
              "path": "document.number"
            }
          }
        }
      ]
    },
    {
      "key": "seller_buyer",
      "type": "seller_buyer",
      "order": 1,
      "enabled": true,
      "locked": false,
      "layoutMode": "grid",
      "blocks": [
        {
          "key": "seller_identity",
          "type": "company_identity",
          "props": {
            "showAddress": true,
            "showNip": true,
            "showRegon": false,
            "showBankAccount": false
          },
          "layout": {
            "widthMode": "fraction",
            "widthValue": 0.5,
            "minWidthPx": 220
          }
        },
        {
          "key": "buyer_identity",
          "type": "counterparty_identity",
          "props": {
            "label": "Odbiorca oferty",
            "showAddress": true,
            "showNip": true,
            "showRegon": false
          },
          "layout": {
            "widthMode": "fraction",
            "widthValue": 0.5,
            "minWidthPx": 220
          }
        }
      ]
    },
    {
      "key": "document_meta",
      "type": "document_meta",
      "order": 2,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "document_dates_main",
          "type": "document_dates",
          "props": {
            "showIssueDate": true,
            "showSaleDate": false,
            "showDueDate": true
          }
        }
      ]
    },
    {
      "key": "items_table",
      "type": "items_table",
      "order": 3,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "items_table_main",
          "type": "items_table",
          "props": {
            "showHeader": true,
            "columns": [
              "lp",
              "name",
              "quantity",
              "unit",
              "unitNetPrice",
              "netAmount",
              "grossAmount"
            ]
          }
        }
      ]
    },
    {
      "key": "totals",
      "type": "totals",
      "order": 4,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "totals_table_main",
          "type": "totals_table",
          "props": {
            "showByVatRate": false,
            "showCurrency": true
          }
        }
      ]
    },
    {
      "key": "payment",
      "type": "payment",
      "order": 5,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "payment_main",
          "type": "payment",
          "props": {
            "showMethod": true,
            "showDueDate": true,
            "showDaysNet": true,
            "showBankAccount": true,
            "showBankName": true
          }
        }
      ]
    },
    {
      "key": "notes",
      "type": "notes",
      "order": 6,
      "enabled": true,
      "locked": false,
      "layoutMode": "flow",
      "blocks": [
        {
          "key": "notes_main",
          "type": "notes",
          "props": {
            "label": "Uwagi"
          }
        }
      ]
    }
  ],
  "styleTokens": {
    "fontSizeBase": 11,
    "colorText": "#e8ecf8",
    "colorMuted": "#98a4bf",
    "colorAccent": "#8aa4ff",
    "colorBorder": "rgba(138, 164, 255, 0.25)"
  },
  "locales": {
    "pl": {}
  },
  "printSettings": {
    "headerRepeat": true,
    "tableHeaderRepeat": true,
    "pageBreakBefore": [],
    "orphanControl": true
  },
  "legalConstraints": {
    "inherited": true,
    "documentTypeKey": "oferta",
    "overrides": []
  },
  "numberingPresetKey": null,
  "layoutPresetKey": null
}
