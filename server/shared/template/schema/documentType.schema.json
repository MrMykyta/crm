{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "documentType.schema.json",
  "title": "DocumentTypeCapabilitySchema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key",
    "displayName",
    "capabilities",
    "requiredSections",
    "allowedBlockTypes"
  ],
  "properties": {
    "key": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasVat",
        "hasKSeFFields",
        "hasPaymentBlock",
        "hasItemTable",
        "itemTablePriceVisible",
        "hasWarehouseBlock",
        "hasSignatureBlock",
        "hasCarrierBlock",
        "hasCorrectionReference",
        "hasAdvanceReference",
        "isLegalDocument",
        "requiresSellerNip",
        "requiresBuyerNip",
        "requiresLegalFooter",
        "allowedLocales",
        "defaultLocale"
      ],
      "properties": {
        "hasVat": { "type": "boolean" },
        "hasKSeFFields": { "type": "boolean" },
        "hasPaymentBlock": { "type": "boolean" },
        "hasItemTable": { "type": "boolean" },
        "itemTablePriceVisible": { "type": "boolean" },
        "hasWarehouseBlock": { "type": "boolean" },
        "hasSignatureBlock": { "type": "boolean" },
        "hasCarrierBlock": { "type": "boolean" },
        "hasCorrectionReference": { "type": "boolean" },
        "hasAdvanceReference": { "type": "boolean" },
        "isLegalDocument": { "type": "boolean" },
        "requiresSellerNip": { "type": "boolean" },
        "requiresBuyerNip": { "type": "boolean" },
        "requiresLegalFooter": { "type": "boolean" },
        "allowedLocales": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1,
          "uniqueItems": true
        },
        "defaultLocale": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "requiredSections": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "forbiddenSections": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "lockedSections": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "requiredBindings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "legalConstraintRuleSetKey": {
      "type": "string"
    },
    "defaultSections": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "allowedBlockTypes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "forbiddenBlockTypes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "default": []
    },
    "allowedItemTableColumnSets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sectionHeightEstimates": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    }
  }
}
