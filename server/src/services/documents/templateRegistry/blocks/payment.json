{
  "type": "payment",
  "displayName": "Payment",
  "family": "payment",
  "defaultProps": {
    "showMethod": true,
    "showBankAccount": true,
    "showDueDate": true
  },
  "layout": {
    "widthMode": "fraction",
    "widthValue": 0.5,
    "minWidthPx": 220
  },
  "bindingSchema": {
    "supportedPaths": [
