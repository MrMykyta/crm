# ============================================================
# Server environment template (PRODUCTION-style).
# Copy to .env and fill in real values:  cp server/.env.example server/.env
# `.env` is gitignored — never commit real secrets.
#
# For local development you don't need this file: server/.env.dev is committed
# and loaded automatically when NODE_ENV !== production (see src/config/loadEnv.js).
# ============================================================

# App
NODE_ENV=production
PORT=3000
APP_PUBLIC_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=CHANGE_ME

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=app
MONGO_USER=root
MONGO_PASSWORD=CHANGE_ME
MONGO_AUTH_SOURCE=admin
# MONGO_URI=mongodb://user:pass@host:27017/app?authSource=admin

# Auth / JWT — use long random strings
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_TTL=10m
JWT_REFRESH_TTL_HOURS=4

# Files
FILES_STORAGE_ROOT=/app
FILES_MAX_SIZE_MB=20
FILES_PUBLIC_ENABLED=true
FILES_SIGNING_SECRET=CHANGE_ME
FILES_SIGNED_URL_TTL_SEC=86400

# Mail (Gmail SMTP app password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME=CRM
MAIL_FROM_ADDR=no-reply@your-domain.example
